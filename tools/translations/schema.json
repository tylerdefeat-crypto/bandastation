{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"type": "object",
	"patternProperties": {
		"^[\\s\\S]+$": {
			"type": "object",
			"x-tombi-table-keys-order": {
				"properties": "schema"
			},
			"properties": {
				"nominative": {
					"type": "string"
				},
				"genitive": {
					"type": "string"
				},
				"dative": {
					"type": "string"
				},
				"accusative": {
					"type": "string"
				},
				"instrumental": {
					"type": "string"
				},
				"prepositional": {
					"type": "string"
				},
				"gender": {
					"type": "string",
					"enum": ["male", "female", "neuter", "plural"],
					"default": "male"
				}
			},
			"required": ["nominative"],
			"additionalProperties": false
		}
	},
	"minProperties": 1,
	"maxProperties": 1,
	"additionalProperties": false
}
