/*
    ПАМЯТКА ПО СИНТАКСИСУ preset_record_text:
    NAME [имя] - меняет имя отправителя (отображается в чате).
    SAY [текст] - фраза, которую произносит голограмма.
    DELAY [число] - пауза в децисекундах (10 = 1 секунда).
    SOUND [путь_к_звуку] - проигрывает звук (например, 'sound/machines/ping.ogg' или название из конфига).
    PRESET [путь_к_датуму] - меняет внешний вид голограммы (из списка /datum/preset_holoimage).
    LANGUAGE [путь_к_языку] - меняет язык (например, /datum/language/syndicate).
*/

// Базовый тип для твоих ивентовых дисков (чтобы проще было искать в коде)
/obj/item/disk/holodisk/event
	sticker_icon_state = "y_holo" // Можно сменить на "y_holo" или "g_holo" для цвета

// 1. Диск главного инженера
/obj/item/disk/holodisk/k13event/engineer_report
	name = "Голодиск: Инженерный отчет"
	desc = "Запись главного инженера. На диске видны царапины и следы от пальцев."
	preset_image_type = /datum/preset_holoimage/engineer/ce
	preset_record_text = {"
		NAME СЕ Сергей Воронин
		PRESET /datum/preset_holoimage/nanotrasenprivatesecurity
		SAY Запись для архива СССП.
		DELAY 20
		SOUND 'sound/effects/warning-buzzer.ogg'
		SAY Пятый день не можем откалибровать датчики давления в жилом блоке.
		DELAY 30
		SAY Приборы показывают норму, но люди жалуются, что дышать тяжело, будто воздух "густой".
		DELAY 40
		SAY Вахтер из третьей смены вообще заявил, что видел, как в техотсеке пар из трубы сложился в чье-то лицо.
		DELAY 45
		SAY Бред собачий.
		DELAY 20
		SAY Нам прислали партию новых герметиков, а они пахнут какой-то тухлятиной.
		DELAY 20
		SAY Я не знаю, что там происходит, но это не нормально.
		DELAY 20
		SAY Да, чтобы не забыть - поменял пароль в отдел интенсивной терапии.
		DELAY 30
		SAY Забавно, что пароль "Разум", а не "ЕбанутаяСука".
		DELAY 20
		SAY Ха-ха-ха! Оно, может бы и подошло... Хах...
		DELAY 5
		NAME Система
		SAY Связь прервана.
	"}

// 2. Диск выжившего из медицинского отсека
/obj/item/disk/holodisk/k13event/medic_survivor
	name = "Голодиск: Последняя запись"
	desc = "Запись с медицинского отсека. На диске видны следы крови и царапины."
	preset_image_type = /datum/preset_holoimage/researcher
	preset_record_text = {"
		NAME Врач-исследователь Лиза Коваль
		PRESET /datum/preset_holoimage/researcher
		SAY Я не думала, что все закончится именно так...
		DELAY 30
		SAY Все перекрыто, спасения нет... Это... Конец?
		DELAY 30
		SAY Я пыталась связаться с другими отделами, но связь постоянно прерывается.
		DELAY 30
		SAY Вокруг меня все умирают, а я... Я не могу... Я не хочу умирать...
		SOUND 'sound/mobs/humanoids/human/cry/female_cry1.ogg'
		DELAY 40
		SAY Стена в соседней палате совсем проржавела, ее можно как-то разобрать и проломится через стекло в коридор...
		DELAY 40
		SAY Но я не могу... Я слишком слаба, чтобы это сделать...
		DELAY 40
		SAY Я... Я просто хочу, чтобы это все закончилось...
		DELAY 30
		SAY Мама... Папа... Я люблю вас...
		DELAY 5
		NAME Система
		SAY Связь прервана.
	"}

// 3. Диск врача
/obj/item/disk/holodisk/k13event/medic_note
	name = "Заметка врача"
	desc = "Запись с медицинского отсека."
	preset_image_type = /datum/preset_holoimage/researcher
	preset_record_text = {"
		NAME Врач-исследователь Ольга Соколова
		PRESET /datum/preset_holoimage/researcher
		SAY Конфиденциальная запись.
		DELAY 30
		SAY Я вскрыла тела погибших охранников.
		DELAY 30
		SAY То, что я увидела... это невозможно.
		DELAY 30
		SAY Вокруг меня все умирают, а я... Я не могу... Я не хочу умирать...
		DELAY 40
		SAY Их органы были перестроены, кости изменены, мышцы усилены.
		DELAY 40
		SAY Это не болезнь и не мутация. Это... архитектура....
		DELAY 40
		SAY Это... Она... Делает из них... монстров...
		NAME Система
		SAY Связь прервана.
	"}



